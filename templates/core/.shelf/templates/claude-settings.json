{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} .claude/hooks/shelf-session-start.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} .claude/hooks/shelf-inject-workflow-state.py"
          }
        ]
      }
    ]
  }
}
